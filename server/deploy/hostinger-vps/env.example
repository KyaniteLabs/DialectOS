# Copy this file to env.hostinger on the VPS and fill real values.
# Do not commit env.hostinger.

# Public DNS name that points at the VPS, without scheme.
# Example: dialectos-api.kyanitelabs.tech
DIALECTOS_PUBLIC_HOST=dialectos-api.your-domain.example

# Groq free tier — get an API key at https://console.groq.com
# Free: 30 RPM, 6K TPM, ~14.4K requests/day
# Llama 3.3 70B handles Spanish dialect translation well.
LLM_API_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=gsk_your-groq-api-key-here

# Alternative: home inference server via Tailscale (same as Dclutter).
# Uncomment these and comment out the Groq lines above.
# LLM_API_URL=http://host.docker.internal:1234/v1
# LLM_MODEL=your-loaded-model-name
# LLM_API_FORMAT=openai
# LLM_ALLOW_LOCAL=1

# Rate limiting for the public demo.
DIALECTOS_DEMO_RATE_LIMIT=30
DIALECTOS_DEMO_RATE_WINDOW_MS=60000
